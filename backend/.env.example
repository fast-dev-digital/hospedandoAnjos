# Template das variáveis de ambiente do backend.
# Copie para .env e preencha. NUNCA commitar o .env real.
# Em produção, estas vars vivem nas settings do Coolify (CONTEXT.md).

# Stripe — segredos (sk_...) só no backend, nunca no frontend
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Brevo — CRM / e-mail
BREVO_API_KEY=xkeysib-xxx

# Origem liberada no CORS (domínio do cliente). Ex.: https://prismabrasil.com.br
FRONTEND_ORIGIN=http://localhost:5173

# Porta da API
PORT=3000
