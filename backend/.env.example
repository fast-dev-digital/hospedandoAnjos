# Template das variáveis de ambiente do backend.
# Copie para .env e preencha. NUNCA commitar o .env real.
# Em produção, estas vars vivem nas settings do Coolify (CONTEXT.md).

# Stripe — segredos (sk_...) só no backend, nunca no frontend
STRIPE_SECRET_KEY=sk_test_xxx
# whsec_ do `stripe listen` em dev; do endpoint no dashboard em prod
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Brevo — CRM / e-mail
BREVO_API_KEY=xkeysib-xxx

# Segredo p/ assinar o link de cancelamento (gerar com: openssl rand -hex 32)
BILLING_LINK_SECRET=troque-por-um-valor-aleatorio

# Origem liberada no CORS (domínio do cliente). Ex.: https://prismabrasil.com.br
FRONTEND_ORIGIN=http://localhost:5173

# Base pública da API (usada p/ montar o link de cancelamento). Opcional em dev.
API_BASE_URL=http://localhost:3000

# PIX no checkout avulso. A Stripe BR libera PIX só após ~60 dias de histórico.
# Deixe false até a Stripe habilitar; então mude para true.
PIX_ENABLED=false

# Porta da API
PORT=3000
