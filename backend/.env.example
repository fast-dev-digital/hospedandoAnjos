# Template das variáveis de ambiente do backend.
# Copie para .env e preencha. NUNCA commitar o .env real.
# Em produção, estas vars vivem nas settings do Coolify (CONTEXT.md).

# Asaas — gateway de pagamento (ver ADR-0005). A chave da API ($aact_...) só no
# backend, nunca no frontend.
ASAAS_API_KEY=$aact_xxx
# Token compartilhado que o Asaas envia no header `asaas-access-token` do webhook.
# Você define este valor ao cadastrar o webhook no painel do Asaas.
ASAAS_WEBHOOK_TOKEN=troque-por-um-valor-aleatorio
# Base da API do Asaas. Sandbox em dev; produção em prod. Default = sandbox.
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# Brevo — CRM / e-mail
BREVO_API_KEY=xkeysib-xxx

# Segredo p/ assinar o link de cancelamento (gerar com: openssl rand -hex 32)
BILLING_LINK_SECRET=troque-por-um-valor-aleatorio

# Origem liberada no CORS (domínio do cliente). Ex.: https://prismabrasil.com.br
FRONTEND_ORIGIN=http://localhost:5173

# Base pública da API (usada p/ montar o link de cancelamento). Opcional em dev.
API_BASE_URL=http://localhost:3000

# Porta da API
PORT=3000

# Sentry — monitoramento de erros (opcional). Sem DSN, o Sentry fica desligado.
# Pegar em sentry.io → projeto → Settings → Client Keys (DSN).
SENTRY_DSN=
